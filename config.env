# ----------------------------------------------------------------------------
# kl-erp onboarding config — edit if you need different versions/ports.
# These defaults match Kritilabs' production stack.
# ----------------------------------------------------------------------------

# Where the bench will live (created if missing)
BENCH_DIR="$HOME/frappe-bench"

# Site
SITE="erp.localhost"
ADMIN_PASSWORD="admin"

# MariaDB runs in a Docker container on a NON-default port so it never clashes
# with a local MySQL/MariaDB already on 3306.
DB_CONTAINER="frappe-mariadb"
DB_PORT="3307"
DB_ROOT_PASSWORD="frappe_root_2026"
MARIADB_IMAGE="mariadb:10.6"

# Pinned app versions (git tags / branches)
FRAPPE_VERSION="v15.56.0"
ERPNEXT_VERSION="v15.52.0"
HRMS_VERSION="v15.39.1"
INDIA_COMPLIANCE_VERSION="v15.16.0"

# Kriti app (private) — you must have Bitbucket SSH access
KRITI_REPO="git@bitbucket.org:kritilabs/kl-erp.git"
KRITI_BRANCH="dev"
KRITI_APP_NAME="kriti_app"   # the app's internal module name

# Node version installed system-wide (frappe v15 supports 18/20/22)
NODE_MAJOR="20"

# Control panel
PANEL_PORT="9009"
