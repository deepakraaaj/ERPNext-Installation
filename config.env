# ----------------------------------------------------------------------------
# ERPNext install config — edit if you need different versions/ports.
# ----------------------------------------------------------------------------

# Where the bench will live (created if missing)
BENCH_DIR="$HOME/frappe-bench"

# Site
SITE="erp.localhost"
ADMIN_PASSWORD="admin"

# MariaDB runs in a Docker container on a NON-default port so it never clashes
# with a local MySQL/MariaDB already on 3306.
DB_CONTAINER="frappe-mariadb"
DB_PORT="3307"
DB_ROOT_PASSWORD="frappe_root_2026"
MARIADB_IMAGE="mariadb:10.6"

# Pinned app versions (git tags / branches)
FRAPPE_VERSION="v15.56.0"
ERPNEXT_VERSION="v15.52.0"
HRMS_VERSION="v15.39.1"
INDIA_COMPLIANCE_VERSION="v15.16.0"

# Optional custom app. Leave CUSTOM_APP_REPO empty to skip it entirely.
# If your app is private, make sure the machine has SSH/credentials to clone it.
#   CUSTOM_APP_REPO="git@github.com:your-org/your-app.git"
#   CUSTOM_APP_BRANCH="main"
#   CUSTOM_APP_NAME="your_app"   # the app's internal module name
CUSTOM_APP_REPO=""
CUSTOM_APP_BRANCH=""
CUSTOM_APP_NAME=""

# Node version installed system-wide (frappe v15 supports 18/20/22)
NODE_MAJOR="20"

# Control panel
PANEL_PORT="9009"
